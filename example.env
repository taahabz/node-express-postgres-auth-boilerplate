# ============================================================================
# SkillBridge Backend - Environment Template
# ============================================================================
# 1) Copy this file to `.env`
# 2) Fill values before running app
# 3) Never commit `.env`
#
# Quick start:
#   cp example.env .env
#   npm run prisma:generate
#   npm run prisma:migrate
#   npm run dev


# ============================================================================
# App runtime
# ============================================================================
# development | production | test
NODE_ENV=development

# API port
PORT=3000

# Public app URL used when generating links in emails (OTP/reset links)
APP_BASE_URL=http://localhost:3000

# Comma-separated CORS allowlist.
# Required in production by env validation.
CORS_ORIGIN=http://localhost:5173,http://localhost:3000


# ============================================================================
# Database (PostgreSQL / Neon)
# ============================================================================
# IMPORTANT for Neon + Prisma:
# - Prefer pooled endpoint (`-pooler`) for DATABASE_URL
# - Remove `channel_binding=require`
# - Add `pgbouncer=true` to DATABASE_URL
# - Add `connect_timeout=15`
#
# DATABASE_URL is used by runtime queries.
DATABASE_URL=postgresql://neondb_owner:your-password@ep-your-endpoint-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15

# DIRECT_URL is used by Prisma migration engine.
# Required in production by env validation.
DIRECT_URL=postgresql://neondb_owner:your-password@ep-your-endpoint-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15


# ============================================================================
# JWT auth
# ============================================================================
# Required
JWT_SECRET=replace-with-long-random-secret

# Required in production by env validation
JWT_REFRESH_SECRET=replace-with-different-long-random-secret


# ============================================================================
# Redis
# ============================================================================
# Required in production by env validation.
# Used by rate limit store and resend daily limit counters.

# Local Docker default password
REDIS_PASSWORD=redis_dev_password

# Local (app running on host machine):
REDIS_URL=redis://:redis_dev_password@localhost:6379

# If app runs INSIDE docker-compose network, use instead:
# REDIS_URL=redis://:redis_dev_password@redis:6379


# ============================================================================
# Email delivery provider selection
# ============================================================================
# EMAIL_PROVIDER modes:
# - nodemailer : SMTP only
# - resend     : Resend only
# - auto       : Resend first, then fallback to SMTP after RESEND_DAILY_LIMIT
EMAIL_PROVIDER=auto

# Auto mode threshold (emails/day via Resend before fallback to SMTP)
RESEND_DAILY_LIMIT=1000


# ============================================================================
# Nodemailer / SMTP settings
# ============================================================================
# Required when EMAIL_PROVIDER=nodemailer
# Required when EMAIL_PROVIDER=auto (as fallback path)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# From address used by both SMTP and Resend sending
MAIL_FROM=no-reply@example.com


# ============================================================================
# Resend settings
# ============================================================================
# Required when EMAIL_PROVIDER=resend
# Required when EMAIL_PROVIDER=auto
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx


# ============================================================================
# OTP email verification behavior (code constants, not env-configurable yet)
# ============================================================================
# - OTP length: 6 digits
# - OTP TTL: 10 minutes
# - OTP resend cooldown: 60 seconds
# - Max OTP verify attempts: 5
